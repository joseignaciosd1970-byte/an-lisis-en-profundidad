                        x: "month",
                        y: "weight",
                        fill: "company",
                        r: 4.5,
                        tip: true
                    })
                ]
            });
            container.appendChild(plot);

            // Create customized neat legends for All view
            const uniqueCompanies = [...new Set(historicalTrajectory.map(d => d.company))];
            const colors = plot.scale("color").range;
            uniqueCompanies.forEach((company, idx) => {
                const item = document.createElement("div");
                item.className = "flex items-center gap-1.5 bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded-md text-[10px] font-bold";
                item.innerHTML = `<span class="w-2.5 h-2.5 rounded-full" style="background-color: ${colors[idx % colors.length]}"></span>${company}`;
                legendContainer.appendChild(item);
            });

        } else {
            document.getElementById('chart-main-title').innerHTML = `<span class="material-icons text-castanar-primary dark:text-castanar-light">bar_chart</span> Distribución del Top 10 de Compañías al ${dataset[currentMonth].date}`;
            
            const monthData = dataset[currentMonth];
            const plot = Plot.plot({
                width: container.clientWidth,
                height: 380,
                x: { grid: true, label: "Ponderación en Cartera (%)", domain: [0, 13], stroke: textColor },
                y: { label: null, domain: monthData.positions.map(d => d.name), stroke: textColor },
                grid: { stroke: gridColor },
                style: {
                    background: "transparent",
                    color: textColor
                },
                marks: [
                    Plot.barX(monthData.positions, {
                        x: "weight",
                        y: "name",
                        fill: (d, i) => `var(--chart-${(i % 6) + 1})`,
                        rx: 6,
                        tip: true
                    }),
                    Plot.text(monthData.positions, {
                        x: "weight",
                        y: "name",
                        text: d => `${d.weight}%`,
                        dx: 8,
                        textAnchor: "start",
                        fontWeight: "bold",
                        fill: isDark ? "#ffffff" : "#000000"
                    })
                ]
            });
            container.appendChild(plot);
        }
    }

    function renderGeoDistribution() {
        const container = document.getElementById('geo-distribution-container');
        container.innerHTML = "";
        
        const data = dataset[currentMonth === 'all' ? 'may' : currentMonth].geography;
        
        data.forEach(item => {
            const barWrapper = document.createElement("div");
            barWrapper.className = "space-y-1";
            
            barWrapper.innerHTML = `
                <div class="flex justify-between text-xs font-bold">
                    <span class="text-slate-600 dark:text-slate-400 flex items-center gap-1.5">
                        <span class="inline-block w-2.5 h-2.5 rounded-full bg-castanar-medium"></span>
                        ${item.region}
                    </span>
                    <span class="font-mono text-slate-800 dark:text-white">${item.value}%</span>
                </div>
                <div class="h-2.5 w-full bg-slate-100 dark:bg-slate-800/80 rounded-full overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-castanar-primary to-castanar-light rounded-full transition-all duration-500" style="width: ${item.value}%"></div>
                </div>
            `;
            container.appendChild(barWrapper);
        });
    }

    function renderStyleBreakdown() {
        const barContainer = document.getElementById('style-bar-stack');
        barContainer.innerHTML = "";
        
        const gridContainer = document.getElementById('style-legend-grid');
        gridContainer.innerHTML = "";

        const data = dataset[currentMonth === 'all' ? 'may' : currentMonth].styleBreakdown;

        data.forEach(item => {
            // Stack Bar segment
            const seg = document.createElement("div");
            seg.className = "h-full transition-all duration-500 hover:brightness-110 cursor-help";
            seg.style.width = `${item.value}%`;
            seg.style.backgroundColor = item.color;
            seg.title = `${item.category}: ${item.value}%`;
            barContainer.appendChild(seg);

            // Legend indicators
            const leg = document.createElement("div");
            leg.className = "flex items-center gap-1 text-slate-500 dark:text-slate-400";
            leg.innerHTML = `
                <span class="w-2.5 h-2.5 rounded-sm shrink-0" style="background-color: ${item.color}"></span>
                <span class="truncate">${item.category} (${item.value}%)</span>
            `;
            gridContainer.appendChild(leg);
        });
    }

    function renderSectorDistribution() {
        const container = document.getElementById('sector-grid-container');
        container.innerHTML = "";

        const data = dataset[currentMonth === 'all' ? 'may' : currentMonth].sectors;

        data.forEach(sec => {
            const card = document.createElement("div");
            card.className = "bg-slate-50 dark:bg-slate-900/40 p-4 rounded-xl border border-slate-100 dark:border-slate-800/60 flex flex-col items-center justify-between gap-3 text-center transition-all hover:-translate-y-0.5 hover:shadow-sm";
            
            // Replicating exactly visual features ofUnnamed (4)_2.jpg sectors row
            card.innerHTML = `
                <div class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-500 dark:text-emerald-400">
                    ${sec.value}%
                </div>
                <div class="w-10 h-10 rounded-full bg-gradient-to-br ${sec.color} text-white flex items-center justify-center shadow-md">
                    <span class="material-icons text-xl">${sec.icon}</span>
                </div>
                <div class="text-[11px] font-bold tracking-tight text-slate-600 dark:text-slate-400 truncate w-full">
                    ${sec.name}
                </div>
            `;
            container.appendChild(card);
        });
    }

    function renderHoldingsTable() {
        const tbody = document.getElementById('holdings-table-body');
        tbody.innerHTML = "";

        if (currentMonth === 'all') {
            tbody.innerHTML = `
                <tr>
                    <td colspan="6" class="p-8 text-center text-slate-500 dark:text-slate-400">
                        <span class="material-icons text-3xl block text-slate-300 dark:text-slate-600 mb-2">touch_app</span>
                        Selecciona un mes específico arriba para ver la composición detallada de su cartera holdings.
                    </td>
                </tr>
            `;
            return;
        }

        const data = dataset[currentMonth].positions;
        data.forEach(pos => {
            const tr = document.createElement("tr");
            tr.className = "hover:bg-slate-50/50 dark:hover:bg-slate-900/30 transition-colors";
            
            tr.innerHTML = `
                <td class="p-4 text-center font-mono font-bold text-slate-400">${pos.rank}</td>
                <td class="p-4 font-bold text-slate-900 dark:text-white">${pos.name}</td>
                <td class="p-4 font-mono font-bold text-emerald-600 dark:text-emerald-400">${pos.weight}%</td>
                <td class="p-4">
                    <span class="px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 border border-slate-200/50 dark:border-slate-700/50">
                        ${pos.sector}
                    </span>
                </td>
                <td class="p-4">
                    <span class="px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider bg-castanar-soft/40 dark:bg-castanar-deep/40 text-castanar-primary dark:text-emerald-400 border border-emerald-200/40 dark:border-emerald-900/30">
                        ${pos.style}
                    </span>
                </td>
                <td class="p-4 text-slate-500 dark:text-slate-400 italic text-[11px] font-medium max-w-xs truncate lg:max-w-md" title="${pos.action}">
                    ${pos.action}
                </td>
            `;
            tbody.appendChild(tr);
        });
    }

    function filterTable() {
        const input = document.getElementById('table-search').value.toLowerCase();
        const rows = document.querySelectorAll('#holdings-table-body tr');
        
        rows.forEach(row => {
            const name = row.cells[1]?.textContent.toLowerCase() || "";
            const sector = row.cells[3]?.textContent.toLowerCase() || "";
            if (name.includes(input) || sector.includes(input)) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    }

    function renderEditorial() {
        const container = document.getElementById('editorial-rich-text');
        container.innerHTML = dataset[currentMonth].commentary;
    }

    // Dark Mode Functionality
    function toggleDarkMode() {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        document.getElementById('theme-icon').textContent = isDark ? 'light_mode' : 'dark_mode';
        
        // Re-render plot to pick up correct brand text colors
        renderMainChart();
    }

    // Set initial theme preference
    if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
        document.getElementById('theme-icon').textContent = 'light_mode';
    } else {
        document.documentElement.classList.remove('dark');
        document.getElementById('theme-icon').textContent = 'dark_mode';
    }

    // Initialize View with May data as default
    changeMonth('may');

    // Make charts resizable on page resizing
    window.addEventListener('resize', () => {
        renderMainChart();
    });
</script>

</body>
</html>
